{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "wiki.read_page",
  "description": "Read a wiki page by domain and path. Returns the page frontmatter (title, type, last_updated, etc.) and markdown body separately.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "domain": {
        "type": "string",
        "enum": [
          "research",
          "infra",
          "ai-learning",
          "platform"
        ],
        "description": "Wiki domain"
      },
      "page_path": {
        "type": "string",
        "description": "Path relative to wiki/<domain>/ (e.g., \"reference/run-tests-sh.md\")"
      }
    },
    "required": [
      "domain",
      "page_path"
    ]
  }
}
