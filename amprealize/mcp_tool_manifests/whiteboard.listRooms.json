{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "whiteboard.listRooms",
  "description": "List whiteboard rooms, optionally filtered by status or session. Returns rooms the current user has access to.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "session_id": {
        "type": "string",
        "description": "Filter rooms by brainstorm session ID (optional)"
      },
      "status": {
        "type": "string",
        "enum": ["active", "closed", "archived"],
        "description": "Filter rooms by status (optional, defaults to all)"
      },
      "project_id": {
        "type": "string",
        "description": "Project ID for scoping (optional, uses session)"
      },
      "org_id": {
        "type": "string",
        "description": "Organization ID for multi-tenant context (optional, uses session)"
      },
      "limit": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100,
        "default": 20,
        "description": "Maximum number of rooms to return"
      },
      "offset": {
        "type": "integer",
        "minimum": 0,
        "default": 0,
        "description": "Pagination offset"
      }
    },
    "required": []
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "success": { "type": "boolean" },
      "rooms": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "title": { "type": "string" },
            "status": { "type": "string" },
            "session_id": { "type": "string" },
            "created_by": { "type": "string" },
            "participant_count": { "type": "integer" },
            "created_at": { "type": "string", "format": "date-time" },
            "updated_at": { "type": "string", "format": "date-time" }
          }
        }
      },
      "total": { "type": "integer" },
      "message": { "type": "string" }
    }
  }
}
