# Amprealize Enterprise single-node stack — sample env file.
# Copy to `.env.enterprise` and fill in real values before `docker compose up`.

# --- License ---
AMPREALIZE_LICENSE_KEY=replace-me

# --- Domain ---
AMPREALIZE_DOMAIN=amprealize.example.com
CADDY_EMAIL=ops@example.com
AMPREALIZE_CORS_ORIGINS=https://amprealize.example.com

# --- Database ---
POSTGRES_USER=amprealize
POSTGRES_PASSWORD=replace-with-64-bytes-of-entropy
POSTGRES_DB=amprealize

TELEMETRY_USER=amprealize_telemetry
TELEMETRY_PASSWORD=replace-with-64-bytes-of-entropy
TELEMETRY_DB=amprealize_telemetry

# --- Redis ---
REDIS_PASSWORD=replace-with-32-bytes-of-entropy

# --- JWT ---
AMPREALIZE_JWT_SECRET=replace-with-48-bytes-of-entropy

# --- Image pin (stamp to a release in production) ---
AMPREALIZE_IMAGE=ghcr.io/amprealize/amprealize-enterprise:latest
AMPREALIZE_API_PORT=8000

# --- Observability ---
LOG_LEVEL=info
