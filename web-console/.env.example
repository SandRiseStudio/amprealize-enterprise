# web-console local development environment
# Copy to .env.local and fill in values; never commit secrets.

# --- API ---
VITE_API_BASE_URL=http://localhost:8080

# --- App origin (GUIDEAI-5 / M2 origin split) ---
# Controls which of the two Pages deployments this build targets.
#   console   → app.amprealize.ai (auth-gated SaaS shell, noindex)
#   marketing → amprealize.ai      (indexable wiki / marketing stopgap)
# Local `npm run dev` defaults to `console` so you develop the full shell.
VITE_APP_ORIGIN=console

# --- Public preview (GUIDEAI-5 / M1+M2 kill switch) ---
# 1 → force wiki-only shell regardless of origin (incident rollback path).
# 0 → respect origin-based behaviour (console shows auth, marketing shows wiki).
# The marketing origin forces wiki-only at runtime even when this is 0.
VITE_PUBLIC_PREVIEW=0

# --- Invite-only UX (console / app.amprealize.ai) ---
# Must match API env AMPREALIZE_INVITE_ONLY for first-time OAuth sign-up.
# 1 → show private-preview banner on /login linking to the marketing apex.
# Leave unset or 0 for open registration and local dev.
# Production console deploy sets this via deploy-prod-console.yml.
VITE_INVITE_ONLY=

# --- Observability ---
# Sentry — leave blank to disable
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=dev

# --- PostHog product analytics ---
# Leave VITE_POSTHOG_KEY blank to disable PostHog locally.
# Set VITE_POSTHOG_ENABLED=true to force PostHog on localhost (useful for
# manual verification of event instrumentation during development).
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
VITE_POSTHOG_ENABLED=false

# --- Build metadata ---
# Injected automatically by CI; set manually when testing release correlation.
VITE_GIT_SHA=local
