{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "auth.consentStatus",
  "description": "Poll the status of a consent request by user code. Alias for auth.consentLookup for MCP client compatibility.",
  "inputSchema": {
    "type": "object",
    "required": ["user_code"],
    "properties": {
      "user_code": {
        "type": "string",
        "description": "The user-facing code displayed during device authorization (e.g., 'ABCD-EFGH'). Case-insensitive, hyphens optional."
      }
    },
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "required": ["status"],
    "properties": {
      "user_code": {"type": "string"},
      "status": {"type": "string"},
      "client_id": {"type": "string"},
      "scopes": {
        "type": "array",
        "items": {"type": "string"}
      },
      "surface": {"type": "string"},
      "created_at": {"type": "string", "format": "date-time"},
      "expires_at": {"type": "string", "format": "date-time"},
      "approved_at": {"type": "string", "format": "date-time"},
      "denied_at": {"type": "string", "format": "date-time"},
      "denied_reason": {"type": "string"},
      "error": {"type": "string"}
    },
    "additionalProperties": true
  },
  "errors": []
}
