{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "infra_wiki.query",
  "description": "Search the Infrastructure Wiki for reference docs, how-tos, architecture pages, and troubleshooting guides.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "query": {
        "type": "string",
        "description": "Search text"
      },
      "page_type": {
        "type": "string",
        "enum": ["reference", "howto", "architecture", "troubleshooting", "practice"],
        "description": "Filter by page type"
      },
      "max_results": {
        "type": "integer",
        "description": "Maximum results (default 10)",
        "default": 10
      }
    },
    "required": ["query"]
  }
}
