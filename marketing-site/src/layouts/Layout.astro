---
import '../styles/tokens.css';
import RequestAccessModal from '../components/RequestAccessModal.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  /** Full-height wiki route (iframe stage); relaxes main padding, hides footer */
  wikiShell?: boolean;
  /** Marketing home + sidebar: full-width main, no default content padding */
  appShell?: boolean;
}

const {
  title,
  description = 'Amprealize — behavioral AI for software teams.',
  ogImage = '/og-default.png',
  wikiShell = false,
  appShell = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const ogImageURL = new URL(ogImage, Astro.site).href;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={canonicalURL} />
    <meta name="theme-color" content="#edf5fb" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content="Amprealize" />

    <!-- Twitter / X card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Extra head content injected by pages (JSON-LD, etc.) -->
    <slot name="head" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

  </head>
  <body class:list={{ 'wiki-shell-body': wikiShell, 'app-shell-body': appShell }}>
    <header class="site-header">
      <div class="header-inner">
        <a class="logo" href="/" aria-label="Amprealize home">
          Amprealize
        </a>
        <div class="header-ctas">
          <button type="button" class="btn btn-primary pressable" data-open-request-access>
            Request access
          </button>
        </div>
      </div>
    </header>
    <main class:list={{ 'main-wiki-shell': wikiShell, 'main-app-shell': appShell }}>
      <slot />
    </main>
    <footer class="site-footer" hidden={wikiShell}>
      <div class="footer-inner">
        <p>© {new Date().getFullYear()} Amprealize. Product access may be invite-only during preview.</p>
      </div>
    </footer>

    <RequestAccessModal />

    <script>
      (() => {
        const els = document.querySelectorAll('[data-animate]');
        if (els.length === 0) return;
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.14 }
        );
        for (const el of els) io.observe(el);
      })();
    </script>
  </body>
</html>

<style is:global>
  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }
  body.wiki-shell-body {
    overflow: hidden;
    height: 100vh;
  }
  body.wiki-shell-body,
  body.app-shell-body {
    --marketing-header-offset: 56px;
  }
  main {
    flex: 1;
    width: 100%;
    box-sizing: border-box;
    padding: calc(var(--space-12) + 48px) var(--space-6) var(--space-16);
    display: grid;
    justify-items: center;
  }
  main.main-wiki-shell {
    padding: 0;
    display: block;
    min-height: 0;
    flex: 1;
    overflow: hidden;
  }
  main.main-app-shell {
    padding: 0;
    display: block;
    width: 100%;
    max-width: none;
    min-height: 0;
    flex: 1;
  }
  .container {
    width: 100%;
    max-width: var(--content-max);
    margin: 0 auto;
  }
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: rgba(255, 255, 255, 0.82);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border-subtle);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-6);
    max-width: none;
    margin: 0 auto;
    width: 100%;
  }
  .logo {
    font-weight: 700;
    letter-spacing: -0.04em;
    text-decoration: none;
  }
  .header-ctas {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 14px;
    border-radius: var(--radius-full);
    font-weight: var(--font-semibold);
    text-decoration: none;
    border: 1px solid var(--color-border-default);
    background: var(--color-bg-elevated);
    color: var(--color-text-primary);
    transition:
      transform var(--duration-fast) var(--ease-out-quart),
      background var(--duration-fast) var(--ease-out-quart),
      border-color var(--duration-fast) var(--ease-out-quart);
    will-change: transform;
  }
  .btn:hover {
    background: var(--color-bg-hover);
    border-color: var(--color-border-hover);
  }
  .btn-ghost {
    background: transparent;
  }
  .btn-primary {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }
  .btn-primary:hover {
    background: var(--color-accent-hover);
    border-color: var(--color-accent-hover);
  }
  button.btn {
    font: inherit;
    cursor: pointer;
  }
  .site-footer {
    border-top: 1px solid var(--color-border-subtle);
    background: rgba(255, 255, 255, 0.68);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    color: var(--color-text-tertiary);
    font-size: var(--text-sm);
  }
  .footer-inner {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: var(--space-8) var(--space-6);
  }

  @media (max-width: 520px) {
    .header-inner,
    .footer-inner {
      padding-left: var(--space-4);
      padding-right: var(--space-4);
    }
    main {
      padding-left: var(--space-4);
      padding-right: var(--space-4);
    }
  }
</style>
