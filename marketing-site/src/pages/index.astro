---
import Layout from '../layouts/Layout.astro';
import WikiShellLayout from '../components/WikiShellLayout.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Amprealize',
  url: 'https://amprealize.ai',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'All',
  description: 'Behavioral AI platform for software teams — public wiki and documentation.',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
};
---

<Layout
  title="Amprealize — wiki"
  description="Public wiki and documentation for Amprealize."
  wikiShell={true}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />
  <WikiShellLayout />
</Layout>
