---
import '../styles/marketing-landing.css';
import Layout from '../layouts/Layout.astro';
import AppShell from '../components/AppShell.astro';
import HeroSection from '../components/HeroSection.astro';
import FeaturesSection from '../components/FeaturesSection.astro';
import PlatformSection from '../components/PlatformSection.astro';
import HowItWorksSection from '../components/HowItWorksSection.astro';
import PersonaSection from '../components/PersonaSection.astro';
import SocialProofSection from '../components/SocialProofSection.astro';
import CTASection from '../components/CTASection.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Amprealize',
  url: 'https://amprealize.ai',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'All',
  description: 'Behavioral AI platform for software teams — public wiki and documentation.',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
};
---

<Layout
  title="Amprealize — behavioral AI for software teams"
  description="Amprealize helps teams capture what works, coordinate agents as a system, and reuse behaviors across projects."
  appShell={true}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />
  <AppShell>
    <div class="marketing-landing">
      <HeroSection />
      <FeaturesSection />
      <PlatformSection />
      <HowItWorksSection />
      <PersonaSection />
      <SocialProofSection />
      <CTASection />
    </div>
  </AppShell>
</Layout>
