---
import Layout from '../../layouts/Layout.astro';
import AppShell from '../../components/AppShell.astro';
import WikiMarketingView from '../../components/WikiMarketingView.astro';
import wikiNav from '../../generated/wiki-nav.json';
import {
  getStaticWikiSlugParams,
  loadWikiPageFromSlug,
  type MarketingWikiNav,
} from '../../lib/marketingWiki';

export function getStaticPaths() {
  const nav = wikiNav as MarketingWikiNav;
  return getStaticWikiSlugParams(nav);
}

const { slug } = Astro.params;
if (!slug) throw new Error('Missing slug');

const nav = wikiNav as MarketingWikiNav;
const loaded = await loadWikiPageFromSlug(slug, nav);
if (!loaded) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const { domain, pagePath, title, html, folder, pageType } = loaded;
const pageTitle = `${title} — Amprealize wiki`;
---

<Layout title={pageTitle} description="Public wiki and documentation for Amprealize." wikiShell={true}>
  <AppShell activeSlug={slug}>
    <WikiMarketingView domain={domain} activePath={pagePath} {title} {html} {folder} {pageType} />
  </AppShell>
</Layout>
