---
import wikiNav from '../../generated/wiki-nav.json';
import type { MarketingWikiNav } from '../../lib/marketingWiki';

const { defaultDomain, defaultPath } = wikiNav as MarketingWikiNav;
if (!defaultDomain || !defaultPath) {
  return new Response('Wiki navigation not generated.', { status: 500 });
}
return Astro.redirect(`/wiki/${defaultDomain}/${defaultPath}`, 302);
---
