---
---

<section class="hero" aria-labelledby="hero-heading">
  <div class="hero-grid">
    <div class="hero-copy" data-animate>
      <div class="eyebrow">
        <span class="dot" aria-hidden="true"></span>
        Private preview
      </div>
      <h1 id="hero-heading">Turn every agent run into a reusable behavior.</h1>
      <p class="lede">
        Amprealize helps teams capture what works, coordinate agents as a system, and reuse behaviors across projects.
        Less thrash. Lower inference spend. A calmer way to ship.
      </p>
      <ul class="proof-strip" aria-label="Product highlights">
        <li>
          <span class="proof-ico" aria-hidden="true">
            <svg viewBox="0 0 16 16" fill="none" width="16" height="16">
              <path d="M8 2v3M8 11v3M2 8h3M11 8h3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
              <circle cx="8" cy="8" r="2.5" stroke="currentColor" stroke-width="1.5"></circle>
            </svg>
          </span>
          MCP-native tools
        </li>
        <li>
          <span class="proof-ico" aria-hidden="true">
            <svg viewBox="0 0 16 16" fill="none" width="16" height="16">
              <path d="M3 12V4l5-2 5 2v8l-5 2-5-2Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"></path>
              <path d="M8 2v12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
            </svg>
          </span>
          CLI + VS Code
        </li>
        <li>
          <span class="proof-ico" aria-hidden="true">
            <svg viewBox="0 0 16 16" fill="none" width="16" height="16">
              <path d="M8 2.5 13 5.75v4.5L8 13.5 3 10.25v-4.5L8 2.5Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"></path>
            </svg>
          </span>
          Behavior library
        </li>
      </ul>
      <div class="actions" data-animate style="transition-delay: 70ms">
        <button type="button" class="btn btn-primary pressable" data-open-request-access>
          Request access
        </button>
      </div>
    </div>

    <div class="hero-showcase" data-animate style="transition-delay: 50ms" aria-hidden="true">
      <div class="showcase-stack">
        <div class="panel panel--window">
          <div class="win-chrome">
            <span class="win-dots"><span></span><span></span><span></span></span>
            <span class="win-title">Trace · extraction run</span>
          </div>
          <div class="win-body">
            <div class="trace-line">
              <span class="trace-label">User</span>
              <span class="trace-msg">Ship the billing retry behavior with guardrails.</span>
            </div>
            <div class="trace-line trace-line--agent">
              <span class="trace-label">Agent</span>
              <span class="trace-msg">Drafted behavior v0.3 — reduced redundant tool calls by 38%.</span>
            </div>
            <div class="trace-meta">
              <span class="pill pill--ok">Passed eval</span>
              <span class="pill">Latency 1.2s</span>
            </div>
          </div>
        </div>
        <div class="panel panel--card">
          <div class="card-head">
            <span class="card-badge">Behavior</span>
            <span class="card-ver">v0.3</span>
          </div>
          <p class="card-title">billing-retry-safe</p>
          <p class="card-desc">Reusable playbook for bounded retries + escalation.</p>
          <div class="card-tags">
            <span class="tag">MCP</span>
            <span class="tag">Guardrails</span>
            <span class="tag">Audit</span>
          </div>
        </div>
        <div class="panel panel--rail">
          <div class="rail-row rail-row--active">
            <span class="rail-ico">
              <svg viewBox="0 0 16 16" fill="none" width="14" height="14">
                <path d="M3 6.5 8 2.5 13 6.5V12a1.5 1.5 0 0 1-1.5 1.5h-7A1.5 1.5 0 0 1 3 12V6.5Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"></path>
              </svg>
            </span>
            <span>Studio</span>
          </div>
          <div class="rail-row">
            <span class="rail-ico">
              <svg viewBox="0 0 16 16" fill="none" width="14" height="14">
                <path d="M4 3.5h8v9H4v-9Z" stroke="currentColor" stroke-width="1.5"></path>
                <path d="M4 6.5h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
              </svg>
            </span>
            <span>Boards</span>
          </div>
          <div class="rail-row">
            <span class="rail-ico">
              <svg viewBox="0 0 16 16" fill="none" width="14" height="14">
                <path d="M4 2.5h8l1 2v9H3v-9l1-2Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"></path>
              </svg>
            </span>
            <span>Wiki</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    width: 100%;
    padding-top: var(--space-4);
    padding-bottom: var(--space-4);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(280px, 0.95fr);
    gap: clamp(28px, 5vw, 56px);
    align-items: center;
  }

  .hero-copy {
    min-width: 0;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: var(--text-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    font-weight: var(--font-semibold);
    margin-bottom: var(--space-4);
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: var(--radius-full);
    background: var(--color-accent-tertiary);
    outline: 6px solid rgba(31, 182, 166, 0.1);
  }

  h1 {
    margin: 0 0 var(--space-4);
    letter-spacing: -0.045em;
    line-height: 1.04;
    font-size: clamp(2.15rem, 4.2vw + 0.6rem, 3.35rem);
    font-weight: var(--font-bold);
    color: var(--color-text-primary);
    text-wrap: balance;
  }

  .lede {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: clamp(1rem, 1.1vw + 0.85rem, 1.125rem);
    line-height: var(--leading-relaxed);
    max-width: 38rem;
  }

  .proof-strip {
    list-style: none;
    margin: var(--space-6) 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .proof-strip li {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border-subtle);
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--color-text-secondary);
  }

  .proof-ico {
    display: grid;
    place-items: center;
    color: var(--color-accent);
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-8);
    align-items: center;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 22px;
    border-radius: var(--radius-full);
    font-weight: var(--font-semibold);
    font-size: var(--text-sm);
    text-decoration: none;
    border: 1px solid var(--color-border-default);
    background: var(--color-bg-elevated);
    color: var(--color-text-primary);
    transition:
      transform var(--duration-fast) var(--ease-out-quart),
      background var(--duration-fast) var(--ease-out-quart),
      border-color var(--duration-fast) var(--ease-out-quart);
  }

  .btn:hover {
    background: var(--color-bg-hover);
    border-color: var(--color-border-hover);
  }

  .btn-primary {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
    border-color: var(--color-accent-hover);
  }

  button.btn {
    font: inherit;
    cursor: pointer;
  }

  /* Product showcase composition */
  .hero-showcase {
    position: relative;
    min-height: 280px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .showcase-stack {
    position: relative;
    width: 100%;
    max-width: 420px;
    display: grid;
    gap: var(--space-3);
    animation: hero-float 7s var(--ease-in-out-quart) infinite;
  }

  @keyframes hero-float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-6px);
    }
  }

  .panel {
    border-radius: var(--radius-2xl);
    border: 1px solid rgba(70, 108, 140, 0.2);
    background: rgba(255, 255, 255, 0.78);
    backdrop-filter: blur(14px) saturate(140%);
    -webkit-backdrop-filter: blur(14px) saturate(140%);
  }

  .panel--window {
    overflow: hidden;
  }

  .win-chrome {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: 10px 12px;
    border-bottom: 1px solid var(--color-border-subtle);
    background: rgba(248, 252, 255, 0.85);
  }

  .win-dots {
    display: inline-flex;
    gap: 5px;
  }

  .win-dots span {
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: rgba(100, 116, 139, 0.28);
  }

  .win-dots span:first-child {
    background: rgba(215, 75, 69, 0.55);
  }
  .win-dots span:nth-child(2) {
    background: rgba(201, 133, 23, 0.55);
  }
  .win-dots span:nth-child(3) {
    background: rgba(22, 131, 79, 0.5);
  }

  .win-title {
    font-size: 11px;
    font-weight: var(--font-semibold);
    letter-spacing: 0.04em;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
  }

  .win-body {
    padding: var(--space-4);
    display: grid;
    gap: var(--space-3);
  }

  .trace-line {
    display: grid;
    gap: 4px;
    padding: 10px 10px;
    border-radius: var(--radius-lg);
    background: rgba(248, 250, 252, 0.9);
    border: 1px solid rgba(73, 112, 146, 0.12);
  }

  .trace-line--agent {
    border-color: rgba(34, 118, 210, 0.22);
    background: rgba(34, 118, 210, 0.06);
  }

  .trace-label {
    font-size: 10px;
    font-weight: var(--font-semibold);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
  }

  .trace-msg {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.45;
  }

  .trace-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .pill {
    font-size: 11px;
    font-weight: var(--font-semibold);
    padding: 4px 10px;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border-subtle);
    color: var(--color-text-tertiary);
    background: rgba(255, 255, 255, 0.65);
  }

  .pill--ok {
    border-color: rgba(22, 131, 79, 0.35);
    color: var(--color-success);
    background: rgba(22, 131, 79, 0.08);
  }

  .panel--card {
    padding: var(--space-4);
    margin-left: var(--space-6);
    transform: translateY(-4px);
  }

  .card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
    margin-bottom: var(--space-2);
  }

  .card-badge {
    font-size: 10px;
    font-weight: var(--font-bold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    padding: 3px 8px;
    border-radius: var(--radius-full);
    background: var(--color-accent-subtle);
    border: 1px solid rgba(34, 118, 210, 0.2);
  }

  .card-ver {
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    color: var(--color-text-tertiary);
    font-family: var(--font-mono);
  }

  .card-title {
    margin: 0 0 6px;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
  }

  .card-desc {
    margin: 0 0 var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .tag {
    font-size: 10px;
    font-weight: var(--font-semibold);
    padding: 3px 8px;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border-subtle);
    color: var(--color-text-tertiary);
    background: rgba(255, 255, 255, 0.6);
  }

  .panel--rail {
    position: absolute;
    right: -6px;
    top: 50%;
    transform: translateY(-42%);
    width: 132px;
    padding: var(--space-2);
    display: grid;
    gap: 4px;
    opacity: 0.96;
  }

  .rail-row {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 10px;
    border-radius: var(--radius-lg);
    font-size: 11px;
    font-weight: var(--font-semibold);
    color: var(--color-text-tertiary);
  }

  .rail-row--active {
    color: var(--color-text-primary);
    background: rgba(34, 118, 210, 0.1);
    border: 1px solid rgba(34, 118, 210, 0.18);
  }

  .rail-ico {
    display: grid;
    place-items: center;
    width: 26px;
    height: 26px;
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.75);
    border: 1px solid var(--color-border-subtle);
    color: var(--color-accent);
  }

  .rail-row--active .rail-ico {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }

  @media (max-width: 960px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }

    .hero-showcase {
      order: -1;
      min-height: 0;
      margin-bottom: var(--space-2);
    }

    .showcase-stack {
      max-width: 100%;
      animation-duration: 9s;
    }

    .panel--card {
      margin-left: 0;
      transform: none;
    }

    .panel--rail {
      position: relative;
      right: auto;
      top: auto;
      transform: none;
      width: 100%;
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .rail-row {
      flex-direction: column;
      text-align: center;
      font-size: 10px;
      padding: var(--space-2) var(--space-1);
    }
  }

  @media (max-width: 520px) {
    .proof-strip li {
      width: 100%;
      justify-content: flex-start;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .showcase-stack {
      animation: none;
    }
  }
</style>
