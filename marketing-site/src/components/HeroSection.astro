---
---

<section class="hero" aria-labelledby="hero-heading">
  <div class="hero-grid">
    <div class="hero-copy" data-animate>
      <div class="eyebrow">
        <span class="dot" aria-hidden="true"></span>
        Private preview
      </div>
      <h1 id="hero-heading">Where work, agents, and what works ship together.</h1>
      <p class="lede">
        Plan and track real work. Run AI agents as teammates on actual tasks. Capture the patterns worth keeping so every sprint starts smarter than the last.
      </p>
      <ul class="proof-strip" aria-label="Product highlights">
        <li>
          <span class="proof-ico" aria-hidden="true">
            <svg viewBox="0 0 16 16" fill="none" width="14" height="14">
              <rect x="2" y="3" width="12" height="10" rx="1.5" stroke="currentColor" stroke-width="1.4"></rect>
              <path d="M2 6h12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"></path>
              <path d="M6 3v3M10 3v3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"></path>
            </svg>
          </span>
          Project boards
        </li>
        <li>
          <span class="proof-ico" aria-hidden="true">
            <svg viewBox="0 0 16 16" fill="none" width="14" height="14">
              <circle cx="8" cy="5" r="2.5" stroke="currentColor" stroke-width="1.4"></circle>
              <path d="M3 13c0-2.761 2.239-5 5-5s5 2.239 5 5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"></path>
              <circle cx="13" cy="5" r="1.75" stroke="currentColor" stroke-width="1.2" stroke-dasharray="2 1.2"></circle>
            </svg>
          </span>
          Agent teammates
        </li>
        <li>
          <span class="proof-ico" aria-hidden="true">
            <svg viewBox="0 0 16 16" fill="none" width="14" height="14">
              <path d="M8 2.5 13 5.75v4.5L8 13.5 3 10.25v-4.5L8 2.5Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"></path>
              <path d="M8 2.5v11M3 5.75l5 3.25 5-3.25" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"></path>
            </svg>
          </span>
          Behavior library
        </li>
      </ul>
      <div class="actions" data-animate style="transition-delay: 70ms">
        <button type="button" class="btn btn-primary pressable" data-open-request-access>
          Request access
        </button>
      </div>
    </div>

    <div class="hero-showcase" data-animate style="transition-delay: 50ms" aria-hidden="true">
      <div class="board-mockup">
        <div class="board-bar">
          <div class="board-bar-left">
            <svg viewBox="0 0 12 12" fill="none" width="10" height="10" class="board-back-ico">
              <path d="M7.5 2L4 6l3.5 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
            <span class="board-crumb">GuideAI</span>
            <span class="board-sep">·</span>
            <span class="board-title">Board</span>
          </div>
          <div class="board-bar-right">
            <span class="board-filter">TYPE</span>
            <span class="board-filter">PRIORITY</span>
          </div>
        </div>
        <div class="board-body">
          <div class="board-col">
            <div class="col-label">
              Backlog
              <span class="col-count">5</span>
            </div>
            <div class="bcard">
              <div class="bcard-top">
                <span class="bcard-type bcard-type--goal">Goal</span>
              </div>
              <p class="bcard-name">Metacognitive self-improvement for behavior lifecycle</p>
              <div class="bcard-foot">
                <span class="bcard-avatar"></span>
                <span class="bcard-assignee">Unassigned</span>
              </div>
            </div>
            <div class="bcard">
              <div class="bcard-top">
                <span class="bcard-type bcard-type--task">Task</span>
              </div>
              <p class="bcard-name">Add meta column via Alembic migration</p>
              <div class="bcard-foot">
                <span class="bcard-avatar"></span>
                <span class="bcard-assignee">Unassigned</span>
              </div>
            </div>
          </div>

          <div class="board-col">
            <div class="col-label">
              In Progress
              <span class="col-count">11</span>
            </div>
            <div class="bcard bcard--active">
              <div class="bcard-top">
                <span class="bcard-type bcard-type--feature">Feature</span>
              </div>
              <p class="bcard-name">SaaS Production Launch — M1 + Lanes B–D</p>
              <div class="bcard-foot">
                <span class="bcard-avatar bcard-avatar--agent">A</span>
                <span class="bcard-assignee bcard-assignee--agent">AI Research Ag…</span>
              </div>
            </div>
            <div class="bcard">
              <div class="bcard-top">
                <span class="bcard-type bcard-type--bug">Bug</span>
              </div>
              <p class="bcard-name">Board load time pretty slow</p>
              <div class="bcard-foot">
                <span class="bcard-avatar"></span>
                <span class="bcard-assignee">Unassigned</span>
              </div>
            </div>
          </div>

          <div class="board-col board-col--fade">
            <div class="col-label">
              In Review
              <span class="col-count">6</span>
            </div>
            <div class="bcard">
              <div class="bcard-top">
                <span class="bcard-type bcard-type--feature">Feature</span>
              </div>
              <p class="bcard-name">Login Screen Update</p>
              <div class="bcard-foot">
                <span class="bcard-avatar"></span>
                <span class="bcard-assignee">Unassigned</span>
              </div>
            </div>
            <div class="bcard">
              <div class="bcard-top">
                <span class="bcard-type bcard-type--goal">Goal</span>
              </div>
              <p class="bcard-name">Implement Scalable Whiteboard Architecture</p>
              <div class="bcard-foot">
                <span class="bcard-avatar bcard-avatar--nick">N</span>
                <span class="bcard-assignee">Nick Sanders</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    width: 100%;
    padding-top: var(--space-4);
    padding-bottom: var(--space-4);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(300px, 1fr);
    gap: clamp(24px, 4vw, 48px);
    align-items: center;
  }

  .hero-copy {
    min-width: 0;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: var(--text-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    font-weight: var(--font-semibold);
    margin-bottom: var(--space-4);
  }

  .dot {
    width: 7px;
    height: 7px;
    border-radius: var(--radius-full);
    background: var(--color-accent-tertiary);
    outline: 5px solid rgba(31, 182, 166, 0.12);
  }

  h1 {
    margin: 0 0 var(--space-4);
    letter-spacing: -0.038em;
    line-height: 1.07;
    font-size: clamp(1.75rem, 3vw + 0.5rem, 2.55rem);
    font-weight: var(--font-bold);
    color: var(--color-text-primary);
    text-wrap: balance;
  }

  .lede {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: clamp(0.9375rem, 0.9vw + 0.8rem, 1.0625rem);
    line-height: var(--leading-relaxed);
    max-width: 36rem;
  }

  .proof-strip {
    list-style: none;
    margin: var(--space-5) 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .proof-strip li {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 6px 12px;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border-subtle);
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--color-text-secondary);
  }

  .proof-ico {
    display: grid;
    place-items: center;
    color: var(--color-accent);
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-7);
    align-items: center;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 20px;
    border-radius: var(--radius-full);
    font-weight: var(--font-semibold);
    font-size: var(--text-sm);
    text-decoration: none;
    border: 1px solid var(--color-border-default);
    background: var(--color-bg-elevated);
    color: var(--color-text-primary);
    transition:
      transform var(--duration-fast) var(--ease-out-quart),
      background var(--duration-fast) var(--ease-out-quart),
      border-color var(--duration-fast) var(--ease-out-quart);
  }

  .btn:hover {
    background: var(--color-bg-hover);
    border-color: var(--color-border-hover);
  }

  .btn-primary {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
    border-color: var(--color-accent-hover);
  }

  button.btn {
    font: inherit;
    cursor: pointer;
  }

  /* ── Board mockup ─────────────────────────────────────── */
  .hero-showcase {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .board-mockup {
    width: 100%;
    border-radius: var(--radius-2xl);
    border: 1px solid rgba(70, 108, 140, 0.22);
    background: rgba(255, 255, 255, 0.82);
    backdrop-filter: blur(16px) saturate(140%);
    -webkit-backdrop-filter: blur(16px) saturate(140%);
    overflow: hidden;
    animation: hero-float 8s var(--ease-in-out-quart) infinite;
  }

  @keyframes hero-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-5px); }
  }

  .board-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding: 9px 12px;
    border-bottom: 1px solid var(--color-border-subtle);
    background: rgba(248, 252, 255, 0.9);
  }

  .board-bar-left {
    display: flex;
    align-items: center;
    gap: 6px;
    min-width: 0;
  }

  .board-back-ico {
    color: var(--color-text-tertiary);
    flex-shrink: 0;
  }

  .board-crumb {
    font-size: 11px;
    font-weight: var(--font-semibold);
    color: var(--color-text-tertiary);
    white-space: nowrap;
  }

  .board-sep {
    font-size: 11px;
    color: var(--color-text-disabled);
  }

  .board-title {
    font-size: 11px;
    font-weight: var(--font-bold);
    color: var(--color-text-primary);
    white-space: nowrap;
  }

  .board-bar-right {
    display: flex;
    gap: 5px;
    flex-shrink: 0;
  }

  .board-filter {
    font-size: 9px;
    font-weight: var(--font-bold);
    letter-spacing: 0.07em;
    color: var(--color-text-tertiary);
    padding: 3px 7px;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border-subtle);
    background: rgba(255, 255, 255, 0.7);
  }

  .board-body {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    background: var(--color-border-subtle);
    padding: 0;
  }

  .board-col {
    background: rgba(246, 250, 253, 0.8);
    padding: 10px 8px;
    display: flex;
    flex-direction: column;
    gap: 7px;
    min-width: 0;
  }

  .board-col--fade {
    opacity: 0.72;
  }

  .col-label {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 10px;
    font-weight: var(--font-bold);
    letter-spacing: 0.04em;
    color: var(--color-text-tertiary);
    padding: 0 2px 4px;
    border-bottom: 1px solid var(--color-border-subtle);
    margin-bottom: 2px;
  }

  .col-count {
    font-size: 9px;
    font-weight: var(--font-semibold);
    padding: 1px 5px;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border-subtle);
    background: rgba(255, 255, 255, 0.7);
    color: var(--color-text-tertiary);
  }

  .bcard {
    border-radius: var(--radius-lg);
    border: 1px solid rgba(70, 108, 140, 0.16);
    background: rgba(255, 255, 255, 0.88);
    padding: 8px 8px 7px;
    display: flex;
    flex-direction: column;
    gap: 5px;
    min-width: 0;
  }

  .bcard--active {
    border-color: rgba(34, 118, 210, 0.26);
    background: rgba(34, 118, 210, 0.04);
  }

  .bcard-top {
    display: flex;
    align-items: center;
  }

  .bcard-type {
    font-size: 9px;
    font-weight: var(--font-bold);
    letter-spacing: 0.06em;
    padding: 2px 6px;
    border-radius: var(--radius-full);
  }

  .bcard-type--goal {
    color: #92400e;
    background: rgba(217, 119, 6, 0.1);
    border: 1px solid rgba(217, 119, 6, 0.22);
  }

  .bcard-type--feature {
    color: #1e40af;
    background: rgba(34, 118, 210, 0.1);
    border: 1px solid rgba(34, 118, 210, 0.22);
  }

  .bcard-type--task {
    color: var(--color-text-tertiary);
    background: rgba(100, 116, 139, 0.08);
    border: 1px solid rgba(100, 116, 139, 0.2);
  }

  .bcard-type--bug {
    color: #991b1b;
    background: rgba(215, 75, 69, 0.08);
    border: 1px solid rgba(215, 75, 69, 0.2);
  }

  .bcard-name {
    margin: 0;
    font-size: 10px;
    line-height: 1.4;
    font-weight: var(--font-medium);
    color: var(--color-text-primary);
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
  }

  .bcard-foot {
    display: flex;
    align-items: center;
    gap: 5px;
    margin-top: 1px;
  }

  .bcard-avatar {
    width: 14px;
    height: 14px;
    border-radius: var(--radius-full);
    background: rgba(100, 116, 139, 0.18);
    border: 1px solid rgba(100, 116, 139, 0.2);
    flex-shrink: 0;
    display: grid;
    place-items: center;
    font-size: 7px;
    font-weight: var(--font-bold);
    color: var(--color-text-tertiary);
  }

  .bcard-avatar--agent {
    background: rgba(34, 118, 210, 0.15);
    border-color: rgba(34, 118, 210, 0.3);
    color: var(--color-accent);
  }

  .bcard-avatar--nick {
    background: rgba(16, 152, 173, 0.15);
    border-color: rgba(16, 152, 173, 0.3);
    color: var(--color-accent-secondary);
  }

  .bcard-assignee {
    font-size: 9px;
    color: var(--color-text-tertiary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0;
  }

  .bcard-assignee--agent {
    color: var(--color-accent);
  }

  @media (max-width: 960px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }

    .hero-showcase {
      order: -1;
      margin-bottom: var(--space-2);
    }

    .board-mockup {
      animation: none;
    }
  }

  @media (max-width: 520px) {
    .proof-strip li {
      width: 100%;
      justify-content: flex-start;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .board-mockup {
      animation: none;
    }
  }
</style>
