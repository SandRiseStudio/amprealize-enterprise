<section class="proof" aria-label="Social proof">
  <figure class="proof-quote" data-animate>
    <blockquote cite="https://amprealize.ai">
      <p>
        Amprealize made our agent work feel cumulative. We stopped re-learning the same lessons every run.
      </p>
    </blockquote>
    <figcaption>Private preview user</figcaption>
  </figure>
</section>

<style>
  .proof {
    width: 100%;
    padding-top: var(--landing-section-y, clamp(48px, 7vw, 88px));
  }

  .proof-quote {
    margin: 0;
    padding: var(--space-8) var(--space-8) var(--space-8) var(--space-7);
    border-left: 4px solid var(--color-accent);
    border-radius: 0 var(--radius-2xl) var(--radius-2xl) 0;
    background: rgba(255, 255, 255, 0.55);
    border-top: 1px solid var(--color-border-subtle);
    border-right: 1px solid var(--color-border-subtle);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .proof-quote blockquote {
    margin: 0;
    padding: 0;
  }

  .proof-quote blockquote p {
    margin: 0;
    font-size: clamp(1.2rem, 2vw + 0.6rem, 1.65rem);
    letter-spacing: -0.025em;
    line-height: 1.35;
    font-weight: var(--font-semibold);
    color: var(--color-text-primary);
    max-width: 36rem;
  }

  .proof-quote figcaption {
    margin-top: var(--space-5);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--color-text-tertiary);
  }

  .proof-quote figcaption::before {
    content: '— ';
  }

  @media (max-width: 520px) {
    .proof-quote {
      padding: var(--space-6);
    }
  }
</style>
