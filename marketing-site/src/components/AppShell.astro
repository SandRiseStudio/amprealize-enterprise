---
import wikiNav from '../generated/wiki-nav.json';
import '../styles/console-shell.bundle.css';
import { pickFirstPagePathForDomain, type MarketingWikiNav } from '../lib/marketingWiki';

type WikiPage = { path: string; title: string };
type WikiGroup = { folder: string; label: string; pages?: WikiPage[] };
type WikiDomain = { id: string; label: string; groups: WikiGroup[] };

interface Props {
  /** Slug like `infra/architecture/page.md` for sidebar active states */
  activeSlug?: string | null;
}

const { activeSlug = null } = Astro.props;

const pathname = Astro.url.pathname;
const dashboardActive = pathname === '/' || pathname === '';

const nav = wikiNav as MarketingWikiNav;

function firstPagePathInGroup(group: WikiGroup): string | null {
  const pages = group.pages ?? [];
  if (pages.length === 0) return null;
  const sorted = [...pages].sort((a, b) => a.title.localeCompare(b.title));
  return sorted[0]?.path ?? null;
}

function groupWikiHref(domainId: string, group: WikiGroup): string {
  const fp = firstPagePathInGroup(group);
  if (fp) return `/wiki/${domainId}/${fp}`;
  return `/wiki/${domainId}`;
}

const normalizedActive = activeSlug?.replace(/^\/+|\/+$/g, '') ?? '';

/** Folder key for the group whose first page is the domain default (same as pickFirstPagePathForDomain). */
function overviewFolderForDomain(domain: WikiDomain): string | null {
  const firstPath = pickFirstPagePathForDomain(nav, domain.id);
  if (!firstPath) return null;
  for (const g of domain.groups) {
    if ((g.pages ?? []).some((p) => p.path === firstPath)) {
      return g.folder ?? '';
    }
  }
  return null;
}

function isGroupActive(
  domainId: string,
  folder: string,
  allGroups: WikiGroup[],
  domainOverviewFolder: string | null,
) {
  if (!normalizedActive) return false;
  if (!normalizedActive.startsWith(`${domainId}/`) && normalizedActive !== domainId) return false;
  if (normalizedActive === domainId) {
    return domainOverviewFolder !== null && folder === domainOverviewFolder;
  }
  const rest = normalizedActive.slice(domainId.length + 1);
  if (folder) {
    return rest === folder || rest.startsWith(`${folder}/`);
  }
  const folderSegs = allGroups.map((g) => g.folder).filter(Boolean) as string[];
  const firstSeg = rest.split('/')[0] ?? '';
  if (!firstSeg) return true;
  return !folderSegs.includes(firstSeg);
}
---

<div class="marketing-app-shell wiki-console-host marketing-app-shell--wiki">
  <div class="workspace-shell marketing-app-shell-inner">
    <aside class="workspace-sidebar marketing-app-sidebar" aria-label="Primary navigation">
      <div class="sidebar-header marketing-sidebar-header">
        <a href="/" class="sidebar-toggle pressable" aria-label="Back to marketing home">
          <svg class="sidebar-toggle-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path
              d="M10.5 3.5L5.5 8L10.5 12.5"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </a>
        <a class="sidebar-brand marketing-sidebar-brand" href="/">
          <img
            class="marketing-sidebar-wordmark"
            src="/brand/logo-wordmark-v2.png"
            width="480"
            height="77"
            alt="Amprealize"
            decoding="async"
          />
        </a>
        <span class="marketing-sidebar-header-spacer" aria-hidden="true"></span>
      </div>
      <nav class="sidebar-nav">
        <div class="sidebar-nav-panel">
          <a class:list={['sidebar-nav-item', { active: dashboardActive }]} href="/">
            <span class="sidebar-nav-item-leading">
              <span class="sidebar-nav-icon-wrap">
                <svg class="sidebar-nav-icon" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path
                    d="M3 6.5 8 2.5 13 6.5V12a1.5 1.5 0 0 1-1.5 1.5h-7A1.5 1.5 0 0 1 3 12V6.5Z"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linejoin="round"></path>
                  <path d="M6.25 13.5V9h3.5v4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
                </svg>
              </span>
              <span class="sidebar-nav-copy">
                <span class="sidebar-nav-label">Dashboard</span>
              </span>
            </span>
          </a>
          {
            nav.domains.map((domain) => {
              const overviewFolder = overviewFolderForDomain(domain);
              return (
              <details class="sidebar-section marketing-wiki-domain-block" open data-domain={domain.id}>
                <summary class="sidebar-section-toggle marketing-wiki-domain-summary">
                  <span class="sidebar-section-title-group">
                    <span class="sidebar-section-dot" />
                    <span>{domain.label}</span>
                  </span>
                  <svg class="sidebar-chevron marketing-wiki-domain-chevron" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path
                      d="M6 3.5L10.5 8L6 12.5"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"></path>
                  </svg>
                </summary>
                <div class="sidebar-section-body">
                  <div class="sidebar-section-body-inner">
                    {domain.groups.map((group) => {
                      const folder = group.folder ?? '';
                      const href = groupWikiHref(domain.id, group);
                      const isActive = isGroupActive(domain.id, folder, domain.groups, overviewFolder);
                      return (
                        <a class:list={['sidebar-nav-item', 'nested', { active: isActive }]} href={href}>
                          <span class="sidebar-nav-item-leading">
                            <span class="sidebar-nav-icon-wrap">
                              <svg class="sidebar-nav-icon" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                                <rect x="2.5" y="3" width="11" height="10" rx="1.5" stroke="currentColor" stroke-width="1.5"></rect>
                                <path d="M2 6.5h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
                              </svg>
                            </span>
                            <span class="sidebar-nav-copy">
                              <span class="sidebar-nav-label">{group.label}</span>
                            </span>
                          </span>
                        </a>
                      );
                    })}
                  </div>
                </div>
              </details>
            );
            })
          }
        </div>
      </nav>
      <div class="sidebar-footer marketing-sidebar-footer-spacer" aria-hidden="true" />
    </aside>
    <div class="workspace-content marketing-app-main marketing-app-main--wiki">
      <div class="marketing-app-wiki-slot">
        <slot />
      </div>
    </div>
  </div>
</div>

<style>
  .wiki-console-host.marketing-app-shell--wiki {
    flex: 1 1 0%;
    min-height: 0;
    display: flex;
    flex-direction: column;
  }
  .marketing-app-shell-inner {
    flex: 1 1 0%;
    min-height: 0;
    min-width: 0;
  }
  .marketing-app-sidebar {
    align-self: stretch;
    min-height: 0;
    overflow: hidden;
  }
  .marketing-app-sidebar .sidebar-nav {
    flex: 1 1 0%;
    min-height: 0;
    overflow-y: auto;
    overflow-x: hidden;
    -webkit-overflow-scrolling: touch;
  }
  .marketing-sidebar-footer-spacer {
    flex-shrink: 0;
    min-height: 8px;
    border-top: 1px solid transparent;
  }
  a.marketing-sidebar-brand {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1 1 0%;
    min-width: 0;
    text-decoration: none;
    color: inherit;
  }
  .marketing-sidebar-wordmark {
    height: 32px;
    width: auto;
    max-width: min(260px, 100%);
    display: block;
    object-fit: contain;
    object-position: center;
  }
  .marketing-sidebar-header {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    box-sizing: border-box;
  }
  .marketing-sidebar-header-spacer {
    flex: 0 0 28px;
    width: 28px;
    height: 28px;
    flex-shrink: 0;
  }
  a.sidebar-toggle {
    text-decoration: none;
    color: inherit;
  }
  a.sidebar-nav-item {
    text-decoration: none;
    color: inherit;
    box-sizing: border-box;
  }
  .marketing-wiki-domain-summary {
    list-style: none;
  }
  .marketing-wiki-domain-summary::-webkit-details-marker {
    display: none;
  }
  .marketing-wiki-domain-chevron {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    color: var(--color-text-tertiary);
    transition: transform var(--duration-fast) var(--ease-spring-gentle);
  }
  details.sidebar-section:not([open]) .marketing-wiki-domain-chevron {
    transform: rotate(-90deg);
  }
  .marketing-app-main {
    display: flex;
    flex-direction: column;
    min-width: 0;
    min-height: 0;
    flex: 1 1 0%;
    width: 100%;
  }
  .marketing-app-main--wiki {
    background: #f0f6fb;
    overflow: auto;
    -webkit-overflow-scrolling: touch;
  }
  .marketing-app-wiki-slot {
    flex: 1 1 0%;
    min-width: 0;
    min-height: 0;
    width: 100%;
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
  }
</style>

<style is:global>
  .marketing-app-shell .workspace-sidebar {
    display: flex;
    flex-direction: column;
    align-self: stretch;
    min-height: 0;
    height: 100%;
    max-height: 100%;
    overflow: hidden;
  }
  .marketing-app-shell .workspace-shell {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    width: 100%;
    max-width: 100%;
    flex: 1 1 0%;
    min-height: 0;
    min-width: 0;
    height: 100%;
    max-height: 100%;
    overflow: hidden;
  }
  .marketing-app-shell .workspace-content {
    flex: 1 1 0%;
    min-width: 0;
    min-height: 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  /* Match OSS sidebar: primary blue rail + filled icon chip on active nested rows */
  .marketing-app-shell .sidebar-nav-item.nested.active::before {
    left: 0;
    top: 8px;
    bottom: 8px;
    width: 3px;
    border-radius: 0 3px 3px 0;
    background: var(--color-accent);
  }
  .marketing-app-shell .sidebar-nav-item.nested.active .sidebar-nav-icon-wrap {
    background: var(--color-accent);
    color: #fff;
  }
</style>
