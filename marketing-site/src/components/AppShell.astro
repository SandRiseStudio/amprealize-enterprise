---
import wikiNav from '../generated/wiki-nav.json';
import '../styles/console-shell.bundle.css';

type WikiPage = { path: string; title: string };
type WikiGroup = { folder: string; label: string; pages?: WikiPage[] };
type WikiDomain = { id: string; label: string; groups: WikiGroup[] };

interface Props {
  /** When set, main area is an iframe loading this wiki path (same-origin in prod). */
  wikiPath?: string;
  /** Slug segment after `/wiki/` for active states, e.g. `infra` or `infra/architecture/x.md`. */
  activeSlug?: string | null;
}

const { wikiPath, activeSlug = null } = Astro.props;

const nav = wikiNav as { domains: WikiDomain[]; defaultDomain: string };
const isDev = import.meta.env.DEV;
const devOrigin = (import.meta.env.PUBLIC_WIKI_DEV_ORIGIN ?? 'https://amprealize-web.pages.dev').replace(/\/$/, '');

function topNavPath(path: string) {
  const p = path.startsWith('/') ? path : `/${path}`;
  if (isDev) return `${devOrigin}${p}`;
  return p;
}

function iframeSrc(path: string) {
  const p = path.startsWith('/') ? path : `/${path}`;
  if (isDev) return `${devOrigin}${p}`;
  return p;
}

/** First page in group (same sort as build-wiki-nav / console TOC). */
function firstPagePathInGroup(group: WikiGroup): string | null {
  const pages = group.pages ?? [];
  if (pages.length === 0) return null;
  const sorted = [...pages].sort((a, b) => a.title.localeCompare(b.title));
  return sorted[0]?.path ?? null;
}

function groupWikiHref(domainId: string, group: WikiGroup): string {
  const fp = firstPagePathInGroup(group);
  if (fp) return `/wiki/${domainId}/${fp}`;
  return `/wiki/${domainId}`;
}

const normalizedActive = activeSlug?.replace(/^\/+|\/+$/g, '') ?? '';

function isGroupActive(domainId: string, folder: string, allGroups: WikiGroup[]) {
  if (!normalizedActive) return false;
  if (!normalizedActive.startsWith(`${domainId}/`) && normalizedActive !== domainId) return false;
  if (normalizedActive === domainId) return !folder;
  const rest = normalizedActive.slice(domainId.length + 1);
  if (folder) {
    return rest === folder || rest.startsWith(`${folder}/`);
  }
  const folderSegs = allGroups.map((g) => g.folder).filter(Boolean) as string[];
  const firstSeg = rest.split('/')[0] ?? '';
  if (!firstSeg) return true;
  return !folderSegs.includes(firstSeg);
}

function isDomainActive(domainId: string) {
  if (!normalizedActive) return false;
  return normalizedActive === domainId || normalizedActive.startsWith(`${domainId}/`);
}
---

<div
  class:list={[
    'marketing-app-shell',
    'wiki-console-host',
    { 'marketing-app-shell--wiki': !!wikiPath },
  ]}
>
  <div class="workspace-shell marketing-app-shell-inner">
    <aside class="workspace-sidebar marketing-app-sidebar" aria-label="Wiki navigation">
      <div class="sidebar-header">
        <a class="sidebar-brand-link" href="/" aria-label="Amprealize home">
          <span class="sidebar-brand-mark" aria-hidden="true">A</span>
          <span class="sidebar-brand-text">Amprealize</span>
        </a>
      </div>
      <div class="sidebar-nav">
        <div class="sidebar-nav-panel">
          {
            nav.domains.map((domain) => (
              <div class="sidebar-section marketing-wiki-domain-block" data-domain={domain.id}>
                <a
                  class:list={['sidebar-domain-heading', { 'sidebar-domain-heading--active': isDomainActive(domain.id) }]}
                  href={topNavPath(`/wiki/${domain.id}`)}
                >
                  <div class="sidebar-section-label">
                    <span class="sidebar-section-title-group">
                      <span class="sidebar-section-dot" />
                      <span>{domain.label}</span>
                    </span>
                  </div>
                </a>
                <div class="sidebar-section-body">
                  <div class="sidebar-section-body-inner">
                    {domain.groups.map((group) => {
                      const folder = group.folder ?? '';
                      const href = topNavPath(groupWikiHref(domain.id, group));
                      const isActive = isGroupActive(domain.id, folder, domain.groups);
                      return (
                        <a
                          class:list={['sidebar-nav-item', 'nested', { active: isActive }]}
                          href={href}
                        >
                          <span class="sidebar-nav-copy">
                            <span class="sidebar-nav-label">{group.label}</span>
                          </span>
                        </a>
                      );
                    })}
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </aside>
    <div class:list={['workspace-content', 'marketing-app-main', { 'marketing-app-main--wiki': !!wikiPath }]}>
      {
        wikiPath ? (
          <iframe
            class="wiki-marketing-iframe"
            title="Amprealize wiki"
            src={iframeSrc(wikiPath)}
          />
        ) : (
          <div class="marketing-app-slot">
            <slot />
          </div>
        )
      }
    </div>
  </div>
</div>

<style>
  .wiki-console-host {
    min-height: calc(100vh - var(--marketing-header-offset, 56px));
  }
  .marketing-app-shell-inner {
    min-height: inherit;
  }
  .marketing-app-sidebar {
    align-self: flex-start;
    position: sticky;
    top: var(--marketing-header-offset, 56px);
    max-height: calc(100vh - var(--marketing-header-offset, 56px));
    overflow-y: auto;
  }
  .sidebar-brand-link {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
    text-decoration: none;
    color: inherit;
  }
  .sidebar-brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: var(--radius-md);
    background: var(--color-accent);
    color: #fff;
    font-weight: 700;
    font-size: 0.75rem;
  }
  .sidebar-brand-text {
    font-weight: var(--font-semibold);
    font-size: 0.95rem;
    color: var(--color-text-primary);
  }
  .sidebar-domain-heading {
    text-decoration: none;
    color: inherit;
    display: block;
    border-radius: var(--radius-lg);
    transition: color var(--duration-fast) var(--ease-out-quart);
  }
  .sidebar-domain-heading:hover .sidebar-section-title-group {
    color: var(--color-accent);
  }
  .sidebar-domain-heading--active .sidebar-section-title-group {
    color: var(--color-text-primary);
  }
  .marketing-wiki-domain-block {
    margin-top: var(--space-2);
  }
  a.sidebar-nav-item {
    text-decoration: none;
    color: inherit;
    box-sizing: border-box;
  }
  .marketing-app-main {
    display: flex;
    flex-direction: column;
    min-width: 0;
    min-height: 0;
    flex: 1;
  }
  .marketing-app-main--wiki {
    background: rgba(255, 255, 255, 0.5);
    min-height: calc(100vh - var(--marketing-header-offset, 56px));
  }
  .marketing-app-slot {
    flex: 1;
    min-width: 0;
    width: 100%;
    padding: var(--space-4) var(--space-6);
    box-sizing: border-box;
    overflow-x: clip;
  }
  .wiki-marketing-iframe {
    flex: 1;
    width: 100%;
    min-height: min(70vh, 720px);
    border: 0;
    background: var(--color-bg-app);
  }
  .marketing-app-main--wiki .wiki-marketing-iframe {
    min-height: calc(100vh - var(--marketing-header-offset, 56px));
  }
</style>

<style is:global>
  .marketing-app-shell .workspace-shell {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    width: 100%;
    max-width: 100%;
    min-height: inherit;
    height: auto;
    overflow: visible;
  }
  .marketing-app-shell--wiki .workspace-shell {
    overflow: hidden;
    max-height: calc(100vh - var(--marketing-header-offset, 56px));
  }
  .marketing-app-shell .workspace-content {
    flex: 1;
    min-width: 0;
  }
</style>
