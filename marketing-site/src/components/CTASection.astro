---
---

<section class="cta-wrap" aria-labelledby="cta-heading">
  <div class="cta-band" data-animate>
    <div class="cta-copy">
      <h2 id="cta-heading">Ready to build with behavioral leverage?</h2>
      <p>Request access for the private preview.</p>
    </div>
    <div class="cta-actions">
      <button type="button" class="btn btn-primary pressable" data-open-request-access>
        Request access
      </button>
    </div>
  </div>
</section>

<style>
  .cta-wrap {
    width: 100%;
    padding-top: var(--landing-section-y, clamp(48px, 7vw, 88px));
    padding-bottom: var(--space-12);
  }

  .cta-band {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    padding: var(--space-10) var(--space-8);
    border-radius: var(--radius-2xl);
    border: 1px solid rgba(34, 118, 210, 0.28);
    background: rgba(34, 118, 210, 0.07);
  }

  .cta-copy {
    min-width: min(100%, 28rem);
  }

  .cta-copy h2 {
    margin: 0 0 var(--space-2);
    letter-spacing: -0.03em;
    line-height: var(--leading-tight);
    font-size: clamp(1.35rem, 2vw + 0.5rem, 1.85rem);
    font-weight: var(--font-bold);
  }

  .cta-copy p {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    align-items: center;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 22px;
    border-radius: var(--radius-full);
    font-weight: var(--font-semibold);
    font-size: var(--text-sm);
    text-decoration: none;
    border: 1px solid var(--color-border-default);
    background: var(--color-bg-elevated);
    color: var(--color-text-primary);
    transition:
      transform var(--duration-fast) var(--ease-out-quart),
      background var(--duration-fast) var(--ease-out-quart),
      border-color var(--duration-fast) var(--ease-out-quart);
  }

  .btn:hover {
    background: var(--color-bg-hover);
    border-color: var(--color-border-hover);
  }

  .btn-primary {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
    border-color: var(--color-accent-hover);
  }

  button.btn {
    font: inherit;
    cursor: pointer;
  }

  @media (max-width: 720px) {
    .cta-band {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
