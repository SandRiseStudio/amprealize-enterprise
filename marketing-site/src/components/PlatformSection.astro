---
---

<section class="platform" id="platform" aria-labelledby="platform-heading">
  <header class="platform-head" data-animate>
    <p class="kicker">Behaviors</p>
    <h2 id="platform-heading">From agent run to reusable pattern.</h2>
    <p class="sub">
      When an agent does something well, Amprealize extracts that pattern and turns it into a behavior your whole team can reuse — versioned, tagged, and ready to deploy.
    </p>
  </header>

  <div class="platform-panels" data-animate style="transition-delay: 60ms" aria-hidden="true">
    <!-- Left: Trace window -->
    <div class="panel panel--trace">
      <div class="win-chrome">
        <span class="win-dots">
          <span></span><span></span><span></span>
        </span>
        <span class="win-title">Trace · extraction run</span>
      </div>
      <div class="win-body">
        <div class="trace-line">
          <span class="trace-label">User</span>
          <span class="trace-msg">Ship the billing retry behavior with guardrails.</span>
        </div>
        <div class="trace-line trace-line--agent">
          <span class="trace-label">Agent</span>
          <span class="trace-msg">Drafted behavior v0.3 — reduced redundant tool calls by 38%.</span>
        </div>
        <div class="trace-meta">
          <span class="pill pill--ok">Passed eval</span>
          <span class="pill">Latency 1.2s</span>
        </div>
      </div>
      <div class="trace-arrow" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" width="16" height="16">
          <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
        Extracted as behavior
      </div>
    </div>

    <!-- Connector arrow (desktop) -->
    <div class="panel-connector" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" width="20" height="20">
        <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
    </div>

    <!-- Right: Behavior card -->
    <div class="panel panel--card">
      <div class="card-head">
        <span class="card-badge">Behavior</span>
        <span class="card-ver">v0.3</span>
      </div>
      <p class="card-title">billing-retry-safe</p>
      <p class="card-desc">Reusable playbook for bounded retries + escalation. Guardrails enforce idempotency and prevent runaway loops.</p>
      <div class="card-tags">
        <span class="tag">MCP</span>
        <span class="tag">Guardrails</span>
        <span class="tag">Audit</span>
      </div>
      <div class="card-footer">
        <div class="card-stat">
          <span class="card-stat-val">38%</span>
          <span class="card-stat-label">fewer tool calls</span>
        </div>
        <div class="card-stat">
          <span class="card-stat-val">1.2s</span>
          <span class="card-stat-label">avg latency</span>
        </div>
        <div class="card-stat">
          <span class="card-stat-val">✓</span>
          <span class="card-stat-label">eval passed</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Capability callouts -->
  <ul class="callouts" data-animate style="transition-delay: 120ms">
    <li class="callout">
      <span class="callout-ico" aria-hidden="true">
        <svg viewBox="0 0 16 16" fill="none" width="14" height="14">
          <path d="M2 8h12M8 2v12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
        </svg>
      </span>
      <span>Version behaviors like code</span>
    </li>
    <li class="callout">
      <span class="callout-ico" aria-hidden="true">
        <svg viewBox="0 0 16 16" fill="none" width="14" height="14">
          <path d="M3 12V4l5-2 5 2v8l-5 2-5-2Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"></path>
          <path d="M8 2v12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
        </svg>
      </span>
      <span>Share across projects and teams</span>
    </li>
    <li class="callout">
      <span class="callout-ico" aria-hidden="true">
        <svg viewBox="0 0 16 16" fill="none" width="14" height="14">
          <path d="M8 2.5 13 5.75v4.5L8 13.5 3 10.25v-4.5L8 2.5Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"></path>
        </svg>
      </span>
      <span>Cut inference spend on repeated work</span>
    </li>
  </ul>
</section>

<style>
  .platform {
    width: 100%;
    padding-top: var(--landing-section-y, clamp(48px, 7vw, 88px));
  }

  .platform-head {
    max-width: 38rem;
    margin-bottom: var(--space-8);
  }

  .kicker {
    margin: 0 0 var(--space-2);
    font-size: var(--text-xs);
    font-weight: var(--font-bold);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent-secondary);
  }

  .platform-head h2 {
    margin: 0 0 var(--space-3);
    letter-spacing: -0.03em;
    font-size: clamp(1.25rem, 1.6vw + 0.4rem, 1.7rem);
    line-height: var(--leading-tight);
    font-weight: var(--font-bold);
  }

  .sub {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
  }

  /* ── Panels ──────────────────────────────────────────────── */
  .platform-panels {
    display: flex;
    align-items: stretch;
    gap: var(--space-4);
  }

  .panel {
    border-radius: var(--radius-2xl);
    border: 1px solid rgba(70, 108, 140, 0.2);
    background: rgba(255, 255, 255, 0.78);
    backdrop-filter: blur(14px) saturate(140%);
    -webkit-backdrop-filter: blur(14px) saturate(140%);
    flex: 1;
    min-width: 0;
  }

  /* Trace panel */
  .panel--trace {
    display: flex;
    flex-direction: column;
  }

  .win-chrome {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: 10px 14px;
    border-bottom: 1px solid var(--color-border-subtle);
    background: rgba(248, 252, 255, 0.9);
    border-radius: var(--radius-2xl) var(--radius-2xl) 0 0;
  }

  .win-dots {
    display: inline-flex;
    gap: 5px;
  }

  .win-dots span {
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: rgba(100, 116, 139, 0.28);
  }

  .win-dots span:first-child { background: rgba(215, 75, 69, 0.55); }
  .win-dots span:nth-child(2) { background: rgba(201, 133, 23, 0.55); }
  .win-dots span:nth-child(3) { background: rgba(22, 131, 79, 0.5); }

  .win-title {
    font-size: 11px;
    font-weight: var(--font-semibold);
    letter-spacing: 0.04em;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
  }

  .win-body {
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex: 1;
  }

  .trace-line {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 10px 12px;
    border-radius: var(--radius-lg);
    background: rgba(248, 250, 252, 0.9);
    border: 1px solid rgba(73, 112, 146, 0.12);
  }

  .trace-line--agent {
    border-color: rgba(34, 118, 210, 0.22);
    background: rgba(34, 118, 210, 0.06);
  }

  .trace-label {
    font-size: 10px;
    font-weight: var(--font-semibold);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
  }

  .trace-msg {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.45;
  }

  .trace-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .pill {
    font-size: 11px;
    font-weight: var(--font-semibold);
    padding: 4px 10px;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border-subtle);
    color: var(--color-text-tertiary);
    background: rgba(255, 255, 255, 0.65);
  }

  .pill--ok {
    border-color: rgba(22, 131, 79, 0.35);
    color: var(--color-success);
    background: rgba(22, 131, 79, 0.08);
  }

  .trace-arrow {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    border-top: 1px solid var(--color-border-subtle);
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    color: var(--color-accent);
    letter-spacing: 0.02em;
  }

  /* Connector */
  .panel-connector {
    display: flex;
    align-items: center;
    color: var(--color-text-tertiary);
    flex-shrink: 0;
  }

  /* Behavior card panel */
  .panel--card {
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    border-color: rgba(34, 118, 210, 0.24);
    background: rgba(255, 255, 255, 0.82);
  }

  .card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
  }

  .card-badge {
    font-size: 10px;
    font-weight: var(--font-bold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    padding: 3px 8px;
    border-radius: var(--radius-full);
    background: var(--color-accent-subtle);
    border: 1px solid rgba(34, 118, 210, 0.2);
  }

  .card-ver {
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    color: var(--color-text-tertiary);
    font-family: var(--font-mono);
  }

  .card-title {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
  }

  .card-desc {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.58;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .tag {
    font-size: 10px;
    font-weight: var(--font-semibold);
    padding: 3px 9px;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border-subtle);
    color: var(--color-text-tertiary);
    background: rgba(255, 255, 255, 0.65);
  }

  .card-footer {
    display: flex;
    gap: var(--space-4);
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-border-subtle);
    margin-top: auto;
  }

  .card-stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .card-stat-val {
    font-size: var(--text-sm);
    font-weight: var(--font-bold);
    color: var(--color-text-primary);
    font-family: var(--font-mono);
  }

  .card-stat-label {
    font-size: 10px;
    color: var(--color-text-tertiary);
    white-space: nowrap;
  }

  /* ── Callout strip ───────────────────────────────────────── */
  .callouts {
    list-style: none;
    margin: var(--space-6) 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .callout {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border-subtle);
    background: rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--color-text-secondary);
  }

  .callout-ico {
    display: grid;
    place-items: center;
    color: var(--color-accent-secondary);
  }

  @media (max-width: 720px) {
    .platform-panels {
      flex-direction: column;
    }

    .panel-connector {
      display: none;
    }
  }
</style>
